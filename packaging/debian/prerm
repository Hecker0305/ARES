#!/bin/sh
set -e

case "$1" in
    remove|upgrade|deconfigure)
        # Stop service if running
        if command -v systemctl >/dev/null 2>&1; then
            systemctl stop ares-engine.service >/dev/null 2>&1 || true
            systemctl disable ares-engine.service >/dev/null 2>&1 || true
        fi
        ;;
esac

exit 0
