# Ares Engine Configuration
# Copy to .ares.env and fill in your values

# LLM Configuration
ARES_LLM_PROVIDER=ollama
ARES_LLM_BASE_URL=http://localhost:11434/v1
ARES_LLM_MODEL=qwen3:latest
ARES_LLM_API_KEY=

# Attack LLM (for payload generation / jailbreak evolution)
ARES_ATTACK_LLM_PROVIDER=ollama
ARES_ATTACK_LLM_BASE_URL=http://localhost:11434/v1
ARES_ATTACK_LLM_MODEL=qwen3:latest
ARES_ATTACK_LLM_API_KEY=

# Target
ARES_TARGET=

# Scan Settings
ARES_SCAN_MAX_WORKERS=3
ARES_SCAN_MAX_ITERATIONS=200
ARES_WORKERS=3

# OOB Callback Server
ARES_OOB_ENABLED=true
ARES_OOB_PORT=8181

# Web Dashboard
ARES_DASH_PORT=8080

# Output
ARES_OUTPUT=report.txt
ARES_FORMAT=text

# Memory (PostgreSQL DSN for persistent storage)
ARES_MEMORY_DSN=
ARES_MEMORY_ENABLED=false

# Web Server Auth
ARES_ADMIN_PASSWORD=
ARES_ANALYST_PASSWORD=
ARES_READONLY_PASSWORD=
# ARES_PASSWORD_SALT= (auto-generated on first run if empty)

# Sliver C2
ARES_SLIVER_ENABLED=false
ARES_SLIVER_HOST=
ARES_SLIVER_PORT=

# Pivot
ARES_PIVOT_ENABLED=false
ARES_PIVOT_HOST=
ARES_PIVOT_PORT=

# Federated Intelligence
ARES_FEDERATED_ENABLED=true
ARES_FEDERATION_URL=

# Canary / Callback URL
ARES_CANARY_URL=
ARES_DOMAIN=
